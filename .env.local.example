# Where this Next.js app is served in production (no trailing slash). Leave empty on localhost so links stay same-origin.
# Example: https://app.autrifix.com
NEXT_PUBLIC_APP_URL=

# Canonical URL for this deployment (metadataBase, OG/Twitter absolute URLs). No trailing slash.
# Defaults to NEXT_PUBLIC_APP_URL, then localhost. Example marketing: https://autrifix.com — app: https://app.autrifix.com
NEXT_PUBLIC_SITE_URL=

# Django API (include /api/v1)
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000/api/v1

# Optional demo switch — set true to skip real API calls during UI-only testing
NEXT_PUBLIC_ENABLE_OTP_BYPASS=false

# Google Sign-In (Web client ID — same value as GOOGLE_OAUTH_CLIENT_ID on the API)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Optional — enables real Google Maps; omit to use the premium “live grid” fallback
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
