# Django API (include /api/v1)
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000/api/v1

# Optional demo switch — set true to skip real API calls during UI-only testing
NEXT_PUBLIC_ENABLE_OTP_BYPASS=false

# Google Sign-In (Web client ID — same value as GOOGLE_OAUTH_CLIENT_ID on the API)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Optional — enables real Google Maps; omit to use the premium “live grid” fallback
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
